# Google Analytics Configuration
# Get your Property ID from: Google Analytics > Admin > Property Settings
GA_PROPERTY_ID=123456789

# Google Search Console Configuration
# Enter your site URL exactly as it appears in GSC
# Format: https://www.example.com/ or sc-domain:example.com
GSC_SITE_URL=https://www.example.com/

# Shared: Path to your Google Cloud service account JSON key file
# This file should NOT be committed to git
# Download from: Google Cloud Console > Service Accounts > Create Key
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account-key.json
